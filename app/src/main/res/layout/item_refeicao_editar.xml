<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:padding="10dp"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:orientation="vertical"
        android:layout_weight="1"
        android:layout_width="0dp"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvNomeRefeicao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nome"
            android:textSize="16sp"/>

        <EditText
            android:id="@+id/editNomeRefeicao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:hint="Nome"/>

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvHorarioRefeicao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08:00"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>

            <EditText
                android:id="@+id/editHorarioRefeicao"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:hint="HH:mm"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- botões -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <ImageButton
            android:id="@+id/btnAlterarNome"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_nome"
            android:contentDescription="Alterar nome"
            android:scaleType="centerInside"
            android:adjustViewBounds="true"
            android:background="@null"/>

        <ImageButton
            android:id="@+id/btnSalvarNome"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_salvar"
            android:contentDescription="Salvar nome"
            android:scaleType="centerInside"
            android:adjustViewBounds="true"
            android:background="@null"/>

        <ImageButton
            android:id="@+id/btnAlterarHorario"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_time"
            android:contentDescription="Alterar horário"
            android:layout_marginTop="4dp"
            android:scaleType="centerInside"
            android:adjustViewBounds="true"
            android:background="@null"/>

        <ImageButton
            android:id="@+id/btnSalvarHorario"
            android:layout_width="37dp"
            android:layout_height="37dp"
            android:src="@drawable/ic_salvar"
            android:contentDescription="Salvar horário"
            android:visibility="gone"
            android:layout_marginTop="4dp"
            android:scaleType="centerInside"
            android:adjustViewBounds="true"
            android:background="@null"/>

        <ImageButton
            android:id="@+id/btnExcluirRefeicao"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_delete"
            android:contentDescription="Excluir"
            android:layout_marginTop="6dp"
            android:scaleType="centerInside"
            android:adjustViewBounds="true"
            android:background="@null"/>
    </LinearLayout>

</LinearLayout>
